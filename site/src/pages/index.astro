---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = allPosts.slice(0, 3);

const techStack = [
  'Go', 'TypeScript', 'Node.js', 'NestJS', 'PostgreSQL',
  'MongoDB', 'Redis', 'GraphQL', 'Typesense', 'AWS', 'Docker', 'Kubernetes'
];

const capabilities = [
  {
    icon: '⚡',
    title: 'API & backend architecture',
    description: 'REST and GraphQL APIs, service boundaries, and data models designed to stay maintainable as traffic and team size grow.'
  },
  {
    icon: '🗄️',
    title: 'Databases at scale',
    description: 'Schema design, indexing, and search infrastructure — PostgreSQL, Typesense, Redis — tuned to stay fast under real production load.'
  },
  {
    icon: '☁️',
    title: 'Cloud & infrastructure',
    description: 'Deploying and operating services on AWS with Docker, thinking through failure modes and rollback paths before they matter.'
  },
  {
    icon: '💳',
    title: 'Payments & real-time systems',
    description: 'Idempotent payment integrations, object storage lifecycles, and real-time features built to survive retries and race conditions.'
  }
];

const GITHUB_URL   = 'https://github.com/regmibishal42';
const LINKEDIN_URL = 'https://www.linkedin.com/in/bishal-regmi-319770245/';
const EMAIL        = 'regmibishal42@gmail.com';

const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith('/') ? base.slice(0, -1) : base;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Bishal Regmi',
  jobTitle: 'Backend Developer',
  url: 'https://bishalregmi.com.np',
  sameAs: [GITHUB_URL, LINKEDIN_URL]
};
---

<BaseLayout
  title="Backend Developer"
  description="Bishal Regmi is a backend developer specialising in Go, TypeScript, NestJS, PostgreSQL and distributed systems. Writing deep dives on backend engineering."
  jsonLd={jsonLd}
>
  <!-- ══════════════════════════════════════════
       HERO — fills one full viewport
  ══════════════════════════════════════════ -->
  <section class="hero-section">
    <!-- Left: text content -->
    <div class="hero-left">
      <span class="eyebrow">Available for opportunities</span>

      <h1>
        Hi, I'm <span class="gradient-name">Bishal Regmi</span>
      </h1>

      <p class="tagline">
        Backend developer based in <strong>Kathmandu, Nepal</strong>. I build APIs that handle
        real traffic, databases that stay fast under load, and systems that don't page you at 3 am.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href={`${normalizedBase}/blog/`}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          Read the blog
        </a>
        <a class="btn btn-ghost" href="#contact">Get in touch</a>
      </div>

      <!-- Social links -->
      <div class="social-links">
        <a class="social-link" href={GITHUB_URL} target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.73.5.98 5.24.98 11.52c0 5.02 3.26 9.28 7.78 10.78.57.1.78-.25.78-.55v-1.94c-3.17.69-3.84-1.53-3.84-1.53-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.68 1.25 3.33.96.1-.74.4-1.25.72-1.54-2.53-.29-5.19-1.27-5.19-5.63 0-1.24.44-2.26 1.17-3.06-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.14 1.17a10.9 10.9 0 0 1 5.72 0c2.18-1.48 3.14-1.17 3.14-1.17.62 1.58.23 2.75.11 3.04.73.8 1.17 1.82 1.17 3.06 0 4.37-2.67 5.34-5.21 5.62.41.36.77 1.06.77 2.14v3.17c0 .3.21.66.79.55A11.03 11.03 0 0 0 23.02 11.5C23.02 5.24 18.27.5 12 .5Z"/></svg>
        </a>
        <a class="social-link" href={LINKEDIN_URL} target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.56V9h3.56v11.45Z"/></svg>
        </a>
        <a class="social-link" href={`mailto:${EMAIL}`} aria-label="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>
        </a>
      </div>

      <!-- Tech stack -->
      <div style="margin-top: 2rem;">
        <p class="tech-label">Technologies I work with</p>
        <div class="tech-stack">
          {techStack.map((tech) => <span class="tech-pill">{tech}</span>)}
        </div>
      </div>
    </div>

    <!-- Right: terminal -->
    <div class="hero-right">
      <div class="hero-terminal">
        <div class="terminal-bar">
          <div class="terminal-dots">
            <span class="terminal-dot red"></span>
            <span class="terminal-dot amber"></span>
            <span class="terminal-dot green"></span>
          </div>
          <span class="terminal-title">~/backend-projects — zsh</span>
        </div>
        <div class="terminal-body">
          <div class="t-line"><span class="t-prompt">❯</span><span class="t-cmd">go run main.go</span></div>
          <div class="t-line t-out">Starting server on :8080...</div>
          <div class="t-line t-out">✓ Database connected successfully</div>
          <div class="t-line t-out">✓ Redis cache initialised</div>
          <div class="t-line t-out">✓ Server ready to handle requests</div>
          <div class="t-line t-out muted">INFO [2026-07-04] Performance optimised ⚡</div>
          <div class="t-line"><span class="t-prompt">❯</span><span class="cursor"></span></div>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-row" style="margin-top: 1.5rem;">
        <div class="stat">
          <span class="stat-number">3+</span>
          <span class="stat-label">Years exp</span>
        </div>
        <div class="stat">
          <span class="stat-number">{allPosts.length}</span>
          <span class="stat-label">Blog posts</span>
        </div>
        <div class="stat">
          <span class="stat-number">10+</span>
          <span class="stat-label">Projects</span>
        </div>
        <div class="stat">
          <span class="stat-number">∞</span>
          <span class="stat-label">Coffee cups</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator" aria-hidden="true">
      <span>Scroll</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       BELOW THE FOLD — on scroll
  ══════════════════════════════════════════ -->
  <div class="home-below">

    <!-- What I do -->
    <section id="work">
      <h2 class="section-heading">What I do</h2>
      <div class="capability-grid">
        {capabilities.map((c, i) => (
          <div class="capability-card">
            <span class="capability-icon">{c.icon}</span>
            <span class="capability-index">{String(i + 1).padStart(2, '0')}</span>
            <h3>{c.title}</h3>
            <p>{c.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Recent writing — 3-col grid -->
    {featured.length > 0 && (
      <section>
        <h2 class="section-heading">Recent writing</h2>
        <ul class="blog-grid" style="list-style:none;margin:0;padding:0;">
          {featured.map((post) => (
            <li class="post-item">
              <a href={`${normalizedBase}/blog/${post.slug}/`} class="post-title">{post.data.title}</a>
              <div class="post-meta">
                <span>{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                {post.data.readingTime && <><span class="meta-sep">·</span><span>{post.data.readingTime} min read</span></>}
              </div>
              <p class="post-excerpt">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="tag-row">
                  {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              )}
            </li>
          ))}
        </ul>
        <div class="blog-cta">
          <a class="btn btn-primary" href={`${normalizedBase}/blog/`}>
            View all posts
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </section>
    )}

    <!-- Contact -->
    <section id="contact">
      <h2 class="section-heading">Get in touch</h2>
      <div class="contact-card">
        <p>Best way to reach me is email. I read everything and reply within a day or two.</p>
        <div class="contact-links">
          <a class="btn btn-primary" href={`mailto:${EMAIL}`}>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>
            Email me
          </a>
          <a class="btn btn-ghost" href={GITHUB_URL} target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.73.5.98 5.24.98 11.52c0 5.02 3.26 9.28 7.78 10.78.57.1.78-.25.78-.55v-1.94c-3.17.69-3.84-1.53-3.84-1.53-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.68 1.25 3.33.96.1-.74.4-1.25.72-1.54-2.53-.29-5.19-1.27-5.19-5.63 0-1.24.44-2.26 1.17-3.06-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.14 1.17a10.9 10.9 0 0 1 5.72 0c2.18-1.48 3.14-1.17 3.14-1.17.62 1.58.23 2.75.11 3.04.73.8 1.17 1.82 1.17 3.06 0 4.37-2.67 5.34-5.21 5.62.41.36.77 1.06.77 2.14v3.17c0 .3.21.66.79.55A11.03 11.03 0 0 0 23.02 11.5C23.02 5.24 18.27.5 12 .5Z"/></svg>
            GitHub
          </a>
          <a class="btn btn-ghost" href={LINKEDIN_URL} target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.56V9h3.56v11.45Z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
    </section>

  </div><!-- end .home-below -->
</BaseLayout>
